#include <Arduino.h>
#include <WiFi.h>
#include <PubSubClient.h>
#include <ESP32Servo.h>

const char* ssid = "neo8";
const char* password = "asd123123";
const char* mqtt_server = "broker.hivemq.com";
const int mqtt_port = 1883;

const char* topic_drive_vector = "robot/drive/vector";
const char* topic_drive_rotate = "robot/drive/rotate";
const char* topic_action_kick = "robot/action/kick";
const char* topic_action_dribble = "robot/action/dribble";
const char* topic_status_ultrasonic = "robot/status/ultrasonic";

const int ENA_L = 25, IN1_L = 27, IN2_L = 26;
const int ENA_R = 4,  IN1_R = 2,  IN2_R = 15;
const int ENA_B = 13, IN1_B = 14, IN2_B = 12;
const int TRIG_PIN = 18, ECHO_PIN = 19;
const int KICK_PIN = 23;
const int SERVO_KIRI_PIN = 29;
const int SERVO_KANAN_PIN = 17;

WiFiClient espClient;
Servo servoKiri;
Servo servoKanan;
PubSubClient client(espClient);

const int freq = 20000, res = 8;
const int chanL = 0, chanR = 1, chanB = 2;

int speedL = 255, speedR = 255, speedB = 255;
unsigned long lastCmdTime = 0, lastTeleTime = 0;
bool capitanTerbuka = true, manualOverride = false;
float smoothedDist = 100.0;

void setMotor(int l, int r, int b) {
    digitalWrite(IN1_L, l >= 0 ? HIGH : LOW); digitalWrite(IN2_L, l >= 0 ? LOW : HIGH); ledcWrite(chanL, abs(l));
    digitalWrite(IN1_R, r >= 0 ? HIGH : LOW); digitalWrite(IN2_R, r >= 0 ? LOW : HIGH); ledcWrite(chanR, abs(r));
    digitalWrite(IN1_B, b >= 0 ? HIGH : LOW); digitalWrite(IN2_B, b >= 0 ? LOW : HIGH); ledcWrite(chanB, abs(b));
}

void maju()          { setMotor(speedL, speedR, 0);        Serial.println("[MOVE] maju"); }
void mundur()        { setMotor(-speedL, -speedR, 0);      Serial.println("[MOVE] mundur"); }
void geserKanan()    { setMotor(0, -speedR, speedB);       Serial.println("[MOVE] geser kanan"); }
void geserKiri()     { setMotor(-speedL, 0, -speedB);      Serial.println("[MOVE] geser kiri"); }
void putarKanan()    { setMotor(speedL, -speedR, speedB);  Serial.println("[MOVE] putar kanan"); }
void putarKiri()     { setMotor(-speedL, speedR, -speedB); Serial.println("[MOVE] putar kiri"); }
void berhenti()      { setMotor(0, 0, 0);                  Serial.println("[MOVE] stop"); }

void serongKananDepan()  { setMotor(speedL, 0, speedB);     Serial.println("[MOVE] serong kanan depan"); }
void serongKiriDepan()   { setMotor(0, speedR, speedB);     Serial.println("[MOVE] serong kiri depan"); }
void serongKananBelakang() { setMotor(speedL, 0, -speedB);  Serial.println("[MOVE] serong kanan belakang"); }
void serongKiriBelakang()  { setMotor(0, speedR, -speedB);  Serial.println("[MOVE] serong kiri belakang"); }

void gerakDariVector(float vx, float vy) {
    if (abs(vx) < 0.1 && abs(vy) < 0.1) { berhenti(); return; }
    if (abs(vy) > abs(vx)) {
        if (vy < 0) {
            if (vx > 0.3) serongKananDepan();
            else if (vx < -0.3) serongKiriDepan();
            else maju();
        } else {
            if (vx > 0.3) serongKananBelakang();
            else if (vx < -0.3) serongKiriBelakang();
            else mundur();
        }
    } else {
        if (vx > 0) {
            if (vy < -0.3) serongKananDepan();
            else if (vy > 0.3) serongKananBelakang();
            else geserKanan();
        } else {
            if (vy < -0.3) serongKiriDepan();
            else if (vy > 0.3) serongKiriBelakang();
            else geserKiri();
        }
    }
}

void callback(char* topic, byte* payload, unsigned int length) {
    String msg = "";
    for (int i = 0; i < length; i++) msg += (char)payload[i];
    Serial.print("[MQTT] "); Serial.print(topic); Serial.print(" → "); Serial.println(msg);

    if (strcmp(topic, topic_drive_vector) == 0) {
        int comma1 = msg.indexOf(',');
        if (comma1 > 0) {
            float vx = msg.substring(0, comma1).toFloat();
            int comma2 = msg.indexOf(',', comma1 + 1);
            float vy = msg.substring(comma1 + 1, comma2 > 0 ? comma2 : msg.length()).toFloat();
            Serial.print("[VECTOR] vx="); Serial.print(vx); Serial.print(" vy="); Serial.println(vy);
            gerakDariVector(vx, vy);
            lastCmdTime = millis();
        }
    }
    else if (strcmp(topic, topic_drive_rotate) == 0) {
        float omega = msg.toFloat();
        Serial.print("[ROTATE] omega="); Serial.println(omega);
        if (omega > 0.1) putarKanan();
        else if (omega < -0.1) putarKiri();
        else berhenti();
        lastCmdTime = millis();
    }
    else if (strcmp(topic, topic_action_kick) == 0 && msg == "KICK") {
        if (capitanTerbuka) {
            digitalWrite(KICK_PIN, HIGH); delay(100); digitalWrite(KICK_PIN, LOW);
            Serial.println("[KICK] Fired!");
        } else {
            Serial.println("[KICK] BLOCKED — capitan tertutup");
        }
    }
    else if (strcmp(topic, topic_action_dribble) == 0) {
        if (msg == "LOCK") { servoKiri.write(90); servoKanan.write(90); capitanTerbuka = false; manualOverride = true; Serial.println("[DRIBBLE] LOCK"); }
        else if (msg == "RELEASE") { servoKiri.write(0); servoKanan.write(180); capitanTerbuka = true; manualOverride = true; Serial.println("[DRIBBLE] RELEASE"); }
        else if (msg == "AUTO") { manualOverride = false; Serial.println("[DRIBBLE] AUTO"); }
    }
}

void reconnect() {
    while (!client.connected()) {
        Serial.print("[MQTT] Reconnecting...");
        String id = "KRSBI-"; id += String(random(0xffff), HEX);
        if (client.connect(id.c_str())) {
            Serial.println("CONNECTED");
            client.subscribe(topic_drive_vector);
            client.subscribe(topic_drive_rotate);
            client.subscribe(topic_action_kick);
            client.subscribe(topic_action_dribble);
        } else {
            Serial.print("FAILED ("); Serial.print(client.state()); Serial.println(") retry 5s");
            delay(5000);
        }
    }
}

void setup() {
    Serial.begin(115200);

    pinMode(IN1_L, OUTPUT); pinMode(IN2_L, OUTPUT);
    pinMode(IN1_R, OUTPUT); pinMode(IN2_R, OUTPUT);
    pinMode(IN1_B, OUTPUT); pinMode(IN2_B, OUTPUT);
    pinMode(KICK_PIN, OUTPUT);
    pinMode(TRIG_PIN, OUTPUT);
    pinMode(ECHO_PIN, INPUT);

    ledcSetup(chanL, freq, res); ledcAttachPin(ENA_L, chanL);
    ledcSetup(chanR, freq, res); ledcAttachPin(ENA_R, chanR);
    ledcSetup(chanB, freq, res); ledcAttachPin(ENA_B, chanB);

    digitalWrite(KICK_PIN, LOW);
    berhenti();

    ESP32PWM::allocateTimer(0);
    servoKiri.setPeriodHertz(50);
    servoKanan.setPeriodHertz(50);
    servoKiri.attach(SERVO_KIRI_PIN, 500, 2400);
    servoKanan.attach(SERVO_KANAN_PIN, 500, 2400);
    servoKiri.write(0); servoKanan.write(180);

    WiFi.begin(ssid, password);
    while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
    Serial.println("\n[WIFI] Connected");

    client.setServer(mqtt_server, mqtt_port);
    client.setCallback(callback);
}

void loop() {
    if (!client.connected()) reconnect();
    client.loop();

    if (millis() - lastCmdTime > 1000) berhenti();

    if (millis() - lastTeleTime > 100) {
        lastTeleTime = millis();
        digitalWrite(TRIG_PIN, LOW); delayMicroseconds(2);
        digitalWrite(TRIG_PIN, HIGH); delayMicroseconds(10);
        digitalWrite(TRIG_PIN, LOW);
        long duration = pulseIn(ECHO_PIN, HIGH, 30000);
        float currentDist = (duration == 0) ? 99.0 : duration * 0.034 / 2;
        smoothedDist = (smoothedDist * 0.7) + (currentDist * 0.3);

        if (!manualOverride) {
            if (smoothedDist < 12.0) { servoKiri.write(90); servoKanan.write(90); capitanTerbuka = false; }
            else { servoKiri.write(0); servoKanan.write(180); capitanTerbuka = true; }
        }

        char buf[8]; dtostrf(smoothedDist, 4, 2, buf);
        client.publish(topic_status_ultrasonic, buf);
    }
}
